<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.seneca.hotel.controller.admin.reports.ActivityLogReportController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="From:">
               <font>
                  <Font name="Arial" size="13.0" />
               </font></Label>
            <DatePicker fx:id="fromDate" prefWidth="140.0" />
            <Label text="To:">
               <font>
                  <Font name="Arial" size="13.0" />
               </font></Label>
            <DatePicker fx:id="toDate" prefWidth="140.0" />
            <Region prefHeight="26.0" prefWidth="17.0" />
            <Button fx:id="filterBtn" text="Filter">
               <font>
                  <Font name="Arial Bold Italic" size="13.0" />
               </font></Button>
            <Region prefHeight="26.0" prefWidth="251.0" HBox.hgrow="ALWAYS" />
            <Button fx:id="exportCsvBtn" text="Export CSV">
               <font>
                  <Font name="Arial Bold" size="13.0" />
               </font></Button>
            <Button fx:id="exportTxtBtn" text="Export TXT">
               <font>
                  <Font name="Arial Bold" size="13.0" />
               </font></Button>
         </children>
         <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="14.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <TableView fx:id="logTable" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="colTimestamp" prefWidth="170.0" text="Timestamp" />
            <TableColumn fx:id="colActor" prefWidth="110.0" text="Actor" />
            <TableColumn fx:id="colAction" prefWidth="120.0" text="Action" />
            <TableColumn fx:id="colEntityType" prefWidth="120.0" text="Entity Type" />
            <TableColumn fx:id="colEntityId" prefWidth="106.48052978515625" text="Entity ID" />
            <TableColumn fx:id="colMessage" prefWidth="333.51934814453125" text="Message" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
         <BorderPane.margin>
            <Insets bottom="14.0" left="16.0" right="16.0" />
         </BorderPane.margin>
      </TableView>
   </center>
</BorderPane>

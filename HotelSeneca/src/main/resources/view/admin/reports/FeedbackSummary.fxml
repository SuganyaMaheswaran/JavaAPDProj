<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.seneca.hotel.controller.admin.reports.FeedbackSummaryController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Rating:">
               <font>
                  <Font name="Arial" size="13.0" />
               </font></Label>
            <ComboBox fx:id="ratingCombo" prefWidth="90.0" />
            <Label text="From:">
               <font>
                  <Font name="Arial" size="13.0" />
               </font></Label>
            <DatePicker fx:id="fromDate" prefWidth="120.0" />
            <Label text="To:">
               <font>
                  <Font name="Arial" size="13.0" />
               </font></Label>
            <DatePicker fx:id="toDate" prefWidth="120.0" />
            <Label text="Sentiment:">
               <font>
                  <Font name="Arial" size="13.0" />
               </font></Label>
            <ComboBox fx:id="sentimentCombo" prefWidth="100.0" />
            <Label text="Guest:">
               <font>
                  <Font name="Arial" size="13.0" />
               </font></Label>
            <TextField fx:id="guestField" prefWidth="100.0" promptText="name" />
            <Button fx:id="filterBtn" text="Filter">
               <font>
                  <Font name="Arial Bold Italic" size="13.0" />
               </font></Button>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="exportCsvBtn" text="Export CSV">
               <font>
                  <Font name="Arial Bold" size="13.0" />
               </font></Button>
         </children>
         <padding>
            <Insets bottom="12.0" left="16.0" right="16.0" top="14.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <TableView fx:id="feedbackTable" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="colReservationId" prefWidth="120.0" text="Reservation  Number" />
            <TableColumn fx:id="colGuest" prefWidth="150.0" text="Guest" />
            <TableColumn fx:id="colRating" prefWidth="90.0" text="Rating" />
            <TableColumn fx:id="colComment" prefWidth="330.0" text="Comment" />
            <TableColumn fx:id="colDate" prefWidth="130.0" text="Date" />
            <TableColumn fx:id="colSentiment" prefWidth="120.0" text="Sentiment Tag" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
         <BorderPane.margin>
            <Insets bottom="8.0" left="16.0" right="16.0" />
         </BorderPane.margin>
      </TableView>
   </center>
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="24.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="avgRatingLabel" prefHeight="16.0" prefWidth="175.0" text="Average Rating: 0.0 / 5">
               <font>
                  <Font name="Arial Bold Italic" size="14.0" />
               </font>
            </Label>
            <Label fx:id="tagCountsLabel" text="Top issue tags: —">
               <font>
                  <Font name="Arial Bold Italic" size="14.0" />
               </font></Label>
         </children>
         <padding>
            <Insets bottom="14.0" left="16.0" right="16.0" top="4.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="701.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.seneca.hotel.controller.admin.reports.FeedbackSummaryController">
   <top>
      <VBox prefHeight="96.0" prefWidth="1000.0" spacing="10">
         <HBox alignment="CENTER_LEFT" prefHeight="61.0" prefWidth="1000.0" spacing="10.0" BorderPane.alignment="CENTER">
            <Label text="From:" />
            <DatePicker fx:id="fromDate" prefHeight="26.0" prefWidth="122.0" />
            <Label text="To:" />
            <DatePicker fx:id="toDate" prefWidth="120.0" />
            <Label text="Guest:" />
            <TextField fx:id="guestField" prefWidth="180.0" promptText="Guest name" />
            <Button fx:id="filterBtn" text="Filter">
               <font>
                  <Font name="Arial Bold Italic" size="13.0" />
               </font>
            </Button>
            <Region prefHeight="26.0" prefWidth="142.0" HBox.hgrow="ALWAYS" />
            <Button fx:id="exportCsvBtn" text="Export CSV">
               <font>
                  <Font name="Arial Bold" size="13.0" />
               </font>
            </Button>
            <padding>
               <Insets bottom="8.0" left="16.0" right="16.0" top="0" />
            </padding>
         </HBox>
         <HBox alignment="CENTER_LEFT" prefHeight="43.0" prefWidth="1000.0" spacing="10">
            <Label text="Rating:" />
            <ComboBox fx:id="ratingCombo" prefHeight="26.0" prefWidth="117.0" promptText="Rating" />
            <Label text="Sentiment:" />
            <ComboBox fx:id="sentimentCombo" prefHeight="26.0" prefWidth="127.0" promptText="Sentiment" />
            <Region prefHeight="26.0" prefWidth="15.0" />
            <Region HBox.hgrow="ALWAYS" />
            <padding>
               <Insets bottom="12.0" left="16.0" right="16.0" top="0" />
            </padding>
         </HBox>
      </VBox>
   </top>
   <center>
      <TableView fx:id="feedbackTable" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="colReservationId" prefWidth="182.44345664978027" text="Reservation  Number" />
            <TableColumn fx:id="colGuest" prefWidth="168.70095825195312" text="Guest" />
            <TableColumn fx:id="colRating" prefWidth="140.01852416992188" text="Rating" />
            <TableColumn fx:id="colComment" prefWidth="216.73675537109375" text="Comment" />
            <TableColumn fx:id="colDate" prefWidth="124.76324462890625" text="Date" />
            <TableColumn fx:id="colSentiment" prefWidth="132.77252197265625" text="Sentiment Tag" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
         <BorderPane.margin>
            <Insets bottom="8.0" left="16.0" right="16.0" />
         </BorderPane.margin>
      </TableView>
   </center>
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="24.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="avgRatingLabel" prefHeight="16.0" prefWidth="175.0" text="Average Rating: 0.0 / 5">
               <font>
                  <Font name="Arial Bold Italic" size="14.0" />
               </font>
            </Label>
            <Label fx:id="tagCountsLabel" text="Top issue tags: —">
               <font>
                  <Font name="Arial Bold Italic" size="14.0" />
               </font></Label>
         </children>
         <padding>
            <Insets bottom="14.0" left="16.0" right="16.0" top="4.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>

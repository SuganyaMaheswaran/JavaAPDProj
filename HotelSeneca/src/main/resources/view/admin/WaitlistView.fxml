<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-font-family: 'Arial';" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.seneca.hotel.controller.admin.WaitlistViewController">
   <top>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="WAITLIST">
                     <font>
                        <Font name="Arial Bold" size="20.0" />
                     </font>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="16.0" left="16.0" right="16.0" top="14.0" />
               </padding>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label prefHeight="16.0" prefWidth="149.0" text="Guest Name or Phone#:" />
                  <TextField fx:id="searchField" prefHeight="25.0" prefWidth="243.0" promptText="Find guest by name or phone" />
                  <Button fx:id="filterBtn" text="Filter">
                     <font>
                        <Font name="Arial Bold Italic" size="13.0" />
                     </font></Button>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="convertBtn" onAction="#onConvert" text="Convert to Reservation">
                     <font>
                        <Font name="Arial Bold" size="13.0" />
                     </font></Button>
               </children>
               <padding>
                  <Insets bottom="8.0" left="16.0" right="16.0" top="14.0" />
               </padding>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="Room Type:" />
                  <ComboBox fx:id="roomTypeCombo" prefHeight="25.0" prefWidth="127.0" promptText="Room Type" visibleRowCount="5" />
                  <Region prefHeight="25.0" prefWidth="15.0" />
                  <Label text="Status:" />
                  <ComboBox fx:id="statusCombo" prefWidth="110.0" promptText="Status" visibleRowCount="5" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="addBtn" onAction="#onAdd" prefHeight="25.0" prefWidth="161.0" text="Add to Waitlist">
                     <font>
                        <Font name="Arial Bold" size="13.0" />
                     </font></Button>
               </children>
               <padding>
                  <Insets bottom="16.0" left="16.0" right="16.0" top="0.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </top>
   <center>
      <TableView fx:id="waitlistTable" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="colGuest" prefWidth="160.0" text="Guest" />
            <TableColumn fx:id="colPhone" prefWidth="140.0" text="Phone" />
            <TableColumn fx:id="colRoomType" prefWidth="120.0" text="Room Type" />
            <TableColumn fx:id="colFrom" prefWidth="120.0" text="Date From" />
            <TableColumn fx:id="colTo" prefWidth="120.0" text="Date To" />
            <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
         <BorderPane.margin>
            <Insets bottom="14.0" left="16.0" right="16.0" />
         </BorderPane.margin>
      </TableView>
   </center>
</BorderPane>

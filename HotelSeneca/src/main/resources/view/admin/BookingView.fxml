<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Font?>
<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-font-family: 'Arial';" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <Label text="Guest:">
                    <font>
                        <Font name="Arial" size="13.0"/>
                    </font>
                </Label>
                <TextField fx:id="searchField" prefWidth="200.0" promptText="Name or phone"/>
                <Label text="From:">
                    <font>
                        <Font name="Arial" size="13.0"/>
                    </font>
                </Label>
                <DatePicker fx:id="dateStartPicker" prefWidth="120.0"/>
                <Label text="To:">
                    <font>
                        <Font name="Arial" size="13.0"/>
                    </font>
                </Label>
                <DatePicker fx:id="dateEndPicker" prefWidth="120.0"/>
                <Label text="Status:">
                    <font>
                        <Font name="Arial" size="13.0"/>
                    </font>
                </Label>
                <ComboBox fx:id="statusComboBox" prefWidth="110.0"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button mnemonicParsing="false" text="New Reservation">
                    <font>
                        <Font name="Arial Bold" size="13.0"/>
                    </font>
                </Button>
            </children>

            <padding>
                <Insets bottom="16.0" left="16.0" right="16.0" top="14.0"/>
            </padding>
        </HBox>
    </top>
    <center>
        <TableView fx:id="reservationTable" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn prefWidth="50.0" text="ID" />
                <TableColumn prefWidth="120.0" text="Name" />
                <TableColumn prefWidth="100.0" text="Phone" />
                <TableColumn prefWidth="80.0" text="Room #" />
                <TableColumn prefWidth="100.0" text="Check in" />
                <TableColumn prefWidth="100.0" text="Check out" />
                <TableColumn prefWidth="80.0" text="# of Guests" />
                <TableColumn prefWidth="100.0" text="Payment" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <opaqueInsets>
                <Insets />
            </opaqueInsets>
            <BorderPane.margin>
                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
            </BorderPane.margin>
        </TableView>
    </center>
</BorderPane>

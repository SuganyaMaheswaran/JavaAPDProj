<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-font-family: 'Arial';" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="0.0" left="0.0" right="0.0" top="0.0" />
            </padding>
            <children>
                <TextField fx:id="searchField" prefHeight="26.0" prefWidth="204.0" promptText="Search by name or phone" />
                <DatePicker fx:id="dateStartPicker" prefHeight="26.0" prefWidth="121.0" promptText="Date Start" />
                <DatePicker fx:id="dateEndPicker" prefHeight="26.0" prefWidth="106.0" promptText="Date End" />
                <Region />
                <ComboBox fx:id="statusComboBox" promptText="Status" />
                <Region prefHeight="26.0" prefWidth="82.0" HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" text=" New Reservation" />
            </children>
            <BorderPane.margin>
                <Insets bottom="8.0" left="16.0" right="16.0" top="16.0" />
            </BorderPane.margin>
        </HBox>
    </top>
    <center>
        <TableView fx:id="reservationTable" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn prefWidth="50.0" text="ID" />
                <TableColumn prefWidth="120.0" text="Name" />
                <TableColumn prefWidth="100.0" text="Phone" />
                <TableColumn prefWidth="80.0" text="Room #" />
                <TableColumn prefWidth="100.0" text="Check in" />
                <TableColumn prefWidth="100.0" text="Check out" />
                <TableColumn prefWidth="80.0" text="# of Guests" />
                <TableColumn prefWidth="100.0" text="Payment" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <opaqueInsets>
                <Insets />
            </opaqueInsets>
            <BorderPane.margin>
                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
            </BorderPane.margin>
        </TableView>
    </center>
</BorderPane>

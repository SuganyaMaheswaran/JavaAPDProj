<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="mainPane" prefHeight="700.0" prefWidth="1150.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.seneca.hotel.controller.admin.AdminDashboardController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #5D5D5D;">
         <children>
            <Label text="HOTEL SENECA" textFill="WHITE">
               <font>
                  <Font name="Arial Black" size="24.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="18.0" />
               </VBox.margin>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="userLabel" text="Group4 Admin" textFill="WHITE">
               <font>
                  <Font name="Arial" size="13.0" />
               </font></Label>
            <Button fx:id="logoutBtn" onAction="#onLogout" text="Logout">
               <font>
                  <Font name="Arial Bold" size="13.0" />
               </font></Button>
         </children>
         <padding><Insets bottom="12.0" left="16.0" right="16.0" top="12.0" /></padding>
      </HBox>
   </top>
   <left>
      <VBox prefWidth="190.0" spacing="12.0" style="-fx-background-color: #5D5D5D;" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="bookingsBtn" maxWidth="1.7976931348623157E308" onAction="#showDashboard" text="Bookings">
               <font>
                  <Font name="Arial" size="16.0" />
               </font></Button>
            <Region prefHeight="3.0" prefWidth="162.0" />
            <Button fx:id="reservationsBtn" maxWidth="1.7976931348623157E308" onAction="#showReservations" text="Check Out">
               <font>
                  <Font name="Arial" size="16.0" />
               </font></Button>
            <Region layoutX="24.0" layoutY="632.0" prefHeight="3.0" prefWidth="162.0" />
            <Button fx:id="paymentBtn" maxWidth="1.7976931348623157E308" onAction="#showPayment" text="Payment">
               <font>
                  <Font name="Arial" size="16.0" />
               </font></Button>
            <Region layoutX="24.0" layoutY="67.0" prefHeight="3.0" prefWidth="162.0" />
            <Button fx:id="waitlistBtn" maxWidth="1.7976931348623157E308" onAction="#showWaitlist" text="Waitlist">
               <font>
                  <Font name="Arial" size="16.0" />
               </font></Button>
            <Region layoutX="24.0" layoutY="171.0" prefHeight="3.0" prefWidth="162.0" />
            <Button fx:id="loyaltyBtn" maxWidth="1.7976931348623157E308" onAction="#showLoyalty" text="Loyalty Portal">
               <font>
                  <Font name="Arial" size="16.0" />
               </font></Button>
            <Region layoutX="24.0" layoutY="223.0" prefHeight="3.0" prefWidth="162.0" />
            <Button fx:id="reportsBtn" maxWidth="1.7976931348623157E308" onAction="#showReports" text="Reports">
               <font>
                  <Font name="Arial" size="16.0" />
               </font></Button>
            <Region VBox.vgrow="ALWAYS" />
         </children>
         <padding>
            <Insets bottom="16.0" left="14.0" right="14.0" top="20.0" />
         </padding>
      </VBox>
   </left>
   <center>
      <Label text="Welcome. Select a view from the sidebar" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" prefWidth="450.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.seneca.hotel.controller.admin.ReservationDetailsController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
    
    <Label text="Edit Reservation Details" style="-fx-font-size: 18; -fx-font-weight: bold;" />
    
    <GridPane vgap="12" hgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="100" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="Name:" GridPane.rowIndex="0" />
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        
        <Label text="Check-in:" GridPane.rowIndex="1" />
        <DatePicker fx:id="checkInPicker" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        
        <Label text="Check-out:" GridPane.rowIndex="2" />
        <DatePicker fx:id="checkOutPicker" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        
        <Label text="Room Type:" GridPane.rowIndex="3" />
        <ComboBox fx:id="roomTypeComboBox" maxWidth="Infinity" promptText="Select Room Type" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        
        <Label text="Availability:" GridPane.rowIndex="4" />
        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="4">
            <Button text="Check Availability" onAction="#handleCheckAvailability" />
            <Label fx:id="availabilityLabel" text="-" style="-fx-font-weight: bold;" />
        </HBox>
    </GridPane>

    <Separator />

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Delete" onAction="#handleDelete" style="-fx-background-color: #d9534f; -fx-text-fill: white;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Cancel" onAction="#handleCancel" />
        <Button text="Save Changes" onAction="#handleUpdate" style="-fx-background-color: #5cb85c; -fx-text-fill: white;" />
    </HBox>
</VBox>
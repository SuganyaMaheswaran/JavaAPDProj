<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane style="-fx-font-family: 'Arial';" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.seneca.hotel.controller.admin.LoyaltyViewController">
   <top>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label prefHeight="0.0" prefWidth="170.0" text="LOYALTY">
                     <font><Font name="Arial Bold" size="20.0" /></font>
                  </Label>
               </children>
               <padding><Insets bottom="16.0" left="16.0" right="16.0" top="14.0" /></padding>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="Gues Name or Loyalty#:">
                     <font>
                        <Font name="Arial" size="13.0" />
                     </font>
                  </Label>
                  <TextField fx:id="searchField" prefWidth="240.0" promptText="Find by name or loyalty number" />
                  <Button fx:id="searchBtn" text="Search">
                     <font>
                        <Font name="Arial" size="13.0" />
                     </font></Button>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="enrollBtn" onAction="#onEnroll" prefHeight="26.0" prefWidth="93.0" text="Enroll Guest" textOverrun="CLIP">
                     <font>
                        <Font name="Arial" size="13.0" />
                     </font></Button>
               </children>
               <padding><Insets bottom="16.0" left="16.0" right="16.0" /></padding>
            </HBox>
         </children>
      </VBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.6311288483466363" orientation="VERTICAL" BorderPane.alignment="CENTER">
         <items>
            <VBox spacing="10.0">
               <children>
                  <Label prefHeight="36.0" prefWidth="200.0" text="Loyalty Accounts">
                     <font>
                        <Font name="Arial Bold" size="18.0" />
                     </font>
                  </Label>
                  <TableView fx:id="accountsTable" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colGuest" prefWidth="200.0" text="Guest" />
                        <TableColumn fx:id="colNumber" prefWidth="150.0" text="Loyalty Number" />
                        <TableColumn fx:id="colBalance" prefWidth="144.0" text="Points Balance" />
                        <TableColumn fx:id="colEnrolled" prefWidth="126.0" text="Enrollment Date" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="6.0" left="16.0" right="16.0" />
               </padding>
            </VBox>
            <VBox spacing="10.0">
               <children>
                  <Label fx:id="historyLabel" text="Transaction History Per Selected Account">
                     <font>
                        <Font name="Arial Bold" size="18.0" />
                     </font>
                  </Label>
                  <TableView fx:id="historyTable" prefWidth="814.0" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colDate" prefWidth="151.0" text="Date" />
                        <TableColumn fx:id="colType" prefWidth="150.0" text="Type" />
                        <TableColumn fx:id="colPoints" prefWidth="159.0" text="Points" />
                        <TableColumn fx:id="colReservation" prefWidth="130.0" text="Reservation Number" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="12.0" left="16.0" right="16.0" top="12.0" />
               </padding>
            </VBox>
         </items>
      </SplitPane>
   </center>
</BorderPane>

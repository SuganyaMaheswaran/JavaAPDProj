<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ca.seneca.hotel.controller.FeedbackController">

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true">
            <content>
                <VBox alignment="TOP_CENTER"
                      spacing="20"
                      maxWidth="800">

                    <padding>
                        <Insets top="30"
                                right="50"
                                bottom="30"
                                left="50"/>
                    </padding>

                    <!-- TITLE -->
                    <Label text="Guest Feedback"
                           style="-fx-font-size:28px;
                                  -fx-font-weight:bold;"/>
                    <Label text="Feedback is only available after checkout. Please verify your booking to continue."
                           wrapText="true"/>
                    <Separator/>

                    <!-- VERIFY BOOKING -->
                    <VBox spacing="10"
                          prefWidth="400">

                        <Label text="Email Address"/>
                        <TextField fx:id="emailField"
                                   promptText="Enter email used for booking"/>
                        <Button text="Verify Booking"
                                onAction="#verifyBooking"
                                maxWidth="Infinity"/>
                    </VBox>
                    <Separator/>

                    <!-- FEEDBACK SECTION -->
                    <VBox fx:id="feedbackSection"
                          spacing="20"
                          visible="true"
                          managed="true"
                          prefWidth="600">

                        <Label text="Rate Your Stay"
                               style="-fx-font-size:22px;
                                      -fx-font-weight:bold;"/>

                        <GridPane hgap="20"
                                  vgap="15">

                            <!-- OVERALL -->
                            <Label text="Overall Experience:"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="0"/>

                            <HBox spacing="5"
                                  GridPane.rowIndex="0"
                                  GridPane.columnIndex="1">

                              <Button fx:id="overallStar1"
							        text="☆"
							        onAction="#rateOverall"/>
							
							<Button fx:id="overallStar2"
							        text="☆"
							        onAction="#rateOverall"/>
							
							<Button fx:id="overallStar3"
							        text="☆"
							        onAction="#rateOverall"/>
							
							<Button fx:id="overallStar4"
							        text="☆"
							        onAction="#rateOverall"/>
							
							<Button fx:id="overallStar5"
							        text="☆"
							        onAction="#rateOverall"/>
                            </HBox>

                            <!-- CLEANLINESS -->
                            <Label text="Cleanliness:"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="0"/>

                            <HBox spacing="5"
                                  GridPane.rowIndex="1"
                                  GridPane.columnIndex="1">

                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>
                            </HBox>

                            <!-- SERVICE -->
                            <Label text="Staff Service:"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="0"/>

                            <HBox spacing="5"
                                  GridPane.rowIndex="2"
                                  GridPane.columnIndex="1">

                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>

                            </HBox>

                            <!-- COMFORT -->
                            <Label text="Room Comfort:"
                                   GridPane.rowIndex="3"
                                   GridPane.columnIndex="0"/>

                            <HBox spacing="5"
                                  GridPane.rowIndex="3"
                                  GridPane.columnIndex="1">

                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>
                            </HBox>

                            <!-- VALUE -->
                            <Label text="Value For Money:"
                                   GridPane.rowIndex="4"
                                   GridPane.columnIndex="0"/>

                            <HBox spacing="5"
                                  GridPane.rowIndex="4"
                                  GridPane.columnIndex="1">

                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>
                                <Button text="☆"/>
                            </HBox>
                        </GridPane>

                        <Label text="Additional Comments"/>

                        <TextArea fx:id="feedbackArea"
                                  prefHeight="150"
                                  wrapText="true"
                                  promptText="Tell us about your stay..."/>

                        <Button text="Submit Feedback"
                                onAction="#submitFeedback"
                                maxWidth="200"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>